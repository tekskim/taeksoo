{
  "name": "@ThakiCloud/shared",
  "version": "1.9.3",
  "description": "THAKI Cloud Design System — React component library with design tokens.",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@10.8.1",
  "ai": {
    "guide": "./AI_GUIDE.md",
    "description": "Use @thaki/shared import alias in apps (or direct package @ThakiCloud/shared). Badge themes are abbreviated: gre, blu, ylw, gry. Use Typography.Title (not Heading). Toast uses sonner toast.custom + <Toast handleDismiss={...}>."
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./charts": {
      "import": "./dist/charts.js",
      "types": "./dist/charts.d.ts"
    },
    "./index.css": "./dist/index.css",
    "./styles/index.css": "./dist/index.css",
    "./core.css": "./dist/core.css",
    "./styles/core.css": "./dist/core.css",
    "./tokens-only.css": "./dist/tokens-only.css",
    "./tailwind.preset": "./tailwind.preset.js",
    "./public/*": "./dist/public/*"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist/index.js",
    "dist/charts.js",
    "dist/*.css",
    "dist/public/**/*",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "AI_GUIDE.md",
    "tailwind.preset.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ThakiCloud/thaki-shared.git"
  },
  "homepage": "https://github.com/ThakiCloud/thaki-shared#readme",
  "bugs": {
    "url": "https://github.com/ThakiCloud/thaki-shared/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "scripts": {
    "dev": "rspack serve",
    "build:js": "NODE_ENV=production rspack build -c rspack.config.mjs",
    "build:types": "tsc -p tsconfig.build.json",
    "optimize:dist": "node scripts/optimize-dist.js",
    "build": "pnpm run clean && pnpm run generate:tokens && pnpm run generate:tailwind-preset && pnpm run generate:token-docs && pnpm run build:js && pnpm run build:types && pnpm run optimize:dist",
    "preview": "rspack preview",
    "clean": "rimraf dist",
    "generate:tokens": "node scripts/generate-css-tokens.js",
    "generate:tailwind-preset": "node scripts/generate-tailwind-preset.js",
    "generate:token-docs": "node scripts/generate-token-docs.js",
    "tokens:watch": "nodemon --watch tokens/light.json --watch tokens/dark.json --exec \"pnpm run generate:tokens && pnpm run generate:tailwind-preset\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o dist-storybook",
    "lint": "eslint .",
    "verify:package": "node scripts/verify-package.js"
  },
  "peerDependencies": {
    "echarts": ">=5.5.0",
    "echarts-for-react": ">=3.0.0",
    "i18next": ">=23.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "react-i18next": {
      "optional": true
    },
    "i18next": {
      "optional": true
    },
    "echarts": {
      "optional": true
    },
    "echarts-for-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^9.39.3",
    "@rsbuild/core": "^1.3.20",
    "@rsbuild/plugin-react": "^1.3.1",
    "@rspack/cli": "^1.3.10",
    "@rspack/core": "^1.3.10",
    "@rspack/plugin-react-refresh": "^1.4.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@storybook/addon-essentials": "~8.6.15",
    "@storybook/addon-interactions": "~8.6.15",
    "@storybook/react": "~8.6.15",
    "@storybook/test": "~8.6.15",
    "@svgr/webpack": "^8.1.0",
    "@tabler/icons-react": "^3.37.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.18.0",
    "autoprefixer": "^10.4.21",
    "css-loader": "^7.1.2",
    "dotenv": "^16.5.0",
    "echarts": "5.5.1",
    "echarts-for-react": "3.0.2",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^13.0.6",
    "globals": "^17.3.0",
    "html-webpack-plugin": "^5.6.3",
    "postcss": "^8.5.3",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.1.1",
    "react-hook-form": "^7.71.2",
    "rimraf": "^5.0.5",
    "semantic-release": "^25.0.3",
    "storybook": "~8.6.15",
    "storybook-react-rsbuild": "~1.0.3",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.17",
    "ts-loader": "^9.5.2",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "overrides": {
      "dompurify": "^3.3.3"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.77.2",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.4.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "zustand": "^5.0.5"
  }
}
