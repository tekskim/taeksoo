{
  "name": "@thaki/tds",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.14.0",
    "pnpm": ">=10.0.0"
  },
  "description": "THAKI Design System - A comprehensive React component library",
  "author": "THAKI Cloud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThakiCloud/tds_ssot.git"
  },
  "keywords": [
    "react",
    "design-system",
    "components",
    "ui",
    "tailwindcss",
    "typescript"
  ],
  "main": "./dist/tds.cjs",
  "module": "./dist/tds.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tds.mjs",
      "require": "./dist/tds.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "prepare": "husky",
    "tokens": "node scripts/build-tokens.js",
    "locale": "node scripts/locale/parseLocale.cjs locales",
    "dev": "rspack serve --mode development",
    "dev:vite": "vite",
    "build": "pnpm run tokens && rspack build",
    "build:vite": "pnpm run tokens && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "preview": "rspack serve --mode production",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "audit": "pnpm audit",
    "audit:check": "pnpm audit --audit-level=moderate",
    "audit:fix": "pnpm audit --fix",
    "predeploy": "pnpm run build && pnpm run build-storybook && cp -r storybook-static docs/storybook && touch docs/.nojekyll",
    "deploy": "gh-pages -d docs -t",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "sync-notion": "node scripts/sync-notion.mjs",
    "visual-compare": "node scripts/visual-compare.mjs",
    "prepublishOnly": "pnpm run build:lib && pnpm run test:run"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/mona-sans": "^5.2.8",
    "@tabler/icons-react": "^3.35.0",
    "@types/d3": "^7.4.3",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "d3": "^7.9.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.5",
    "framer-motion": "^12.26.2",
    "i18next": "^25.8.0",
    "lucide-react": "^0.562.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.12.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@eslint/js": "^9.39.1",
    "@notionhq/client": "^5.11.1",
    "@rspack/cli": "^1.7.3",
    "@rspack/core": "^1.7.3",
    "@rspack/plugin-react-refresh": "^1.6.0",
    "@storybook/addon-a11y": "^10.1.11",
    "@storybook/addon-docs": "^10.1.11",
    "@storybook/addon-onboarding": "^10.1.11",
    "@storybook/addon-themes": "^10.1.11",
    "@storybook/addon-vitest": "^10.1.11",
    "@storybook/react-vite": "^10.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-storybook": "^10.1.11",
    "eslint-plugin-unused-imports": "^4.3.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "notion-to-md": "^3.1.9",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.57.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.8.1",
    "storybook": "^10.1.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.17",
    "vitest-axe": "^0.1.0"
  }
}
